FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// 将毫米/厘米转换为米
scale   1;

// 几何参数定义 (m)
// --------------------
// 水槽总长2m，水深0.8m（建议空气层也留0.4m~0.8m的空间，此处总高度设为1.2m）
// - X方向 0 到 2
// - Y方向 0 到 1.2  (其中水深为0~0.8m)
// - Z方向 (2D厚度) 通常取0.1m即可

// 假设OWC装置放置在 X=1.0m 处，气室宽度为0.2m (X=1.0 ~ 1.2m)
// 假设前墙厚度0.02m (位于 X=0.98 ~ 1.0)
// 假设后墙厚度0.02m (位于 X=1.2 ~ 1.22)
// 假设前墙的吃水深度为0.15m (从水面0.8m处向下延伸，即前墙底部在 Y=0.65m 处)
// 假设后墙和前墙一样深，且顶部都延伸至顶部大气边界 Y=1.2m

// 为了用 blockMesh 画出带壁面厚度和深度的复杂结构，我们需要分多个 block，
// 嫌麻烦的话这里展示一个最简化的结构：气室用挡板(baffles)或者后面用 snappyHexMesh 挖出。
// 为了给您最直接可用的代码，这里提供一个采用 topoSet + subsetMesh 形式切出气室的正交底图网格。

vertices
(
    // 整个大水槽的 8 个顶点
    (  0     0     0  )  // 0 : (Xmin, Ymin, Zmin)
    (  2.0   0     0  )  // 1 : (Xmax, Ymin, Zmin)
    (  2.0   1.2   0  )  // 2 : (Xmax, Ymax, Zmin)
    (  0     1.2   0  )  // 3 : (Xmin, Ymax, Zmin)
    
    (  0     0     0.1)  // 4 : (Xmin, Ymin, Zmax)
    (  2.0   0     0.1)  // 5 : (Xmax, Ymin, Zmax)
    (  2.0   1.2   0.1)  // 6 : (Xmax, Ymax, Zmax)
    (  0     1.2   0.1)  // 7 : (Xmin, Ymax, Zmax)
);

blocks
(
    // 划定一个整体 block的网格划分密度
    // 水平方向 2.0m，假设 0.02m一个网格，需要100个
    // 垂直方向 1.2m，假设 0.02m一个网格，需要60个
    // Z方向 1个网格 (保持2D特性)
    hex (0 1 2 3 4 5 6 7) (100 60 1) simpleGrading (1 1 1)
);

edges
(
);

boundary
(
    inlet
    {
        // 对应波浪生成/消波入口 (造波侧)
        type patch;
        faces
        (
            (0 4 7 3)
        );
    }
    outlet
    {
        // 对应波浪生成/消波出口 (消波侧)
        type patch;
        faces
        (
            (1 2 6 5)
        );
    }
    fixedWalls
    {
        // 底部
        type wall;
        faces
        (
            (0 1 5 4)
        );
    }
    atmosphere
    {
        // 顶部大气开口
        type patch;
        faces
        (
            (3 7 6 2)
        );
    }
    frontAndBack
    {
        // 2D 模拟的空面
        type empty;
        faces
        (
            (0 3 2 1)
            (4 5 6 7)
        );
    }
);

mergePatchPairs
(
);

